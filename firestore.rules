rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuth() && getUserData().role == 'superadmin';
    }

    function isRestaurantAdmin(restaurantId) {
      return isAuth() &&
        getUserData().role == 'restaurant' &&
        getUserData().restaurantId == restaurantId;
    }

    // Kitchen / waiter staff. Their Firebase Auth token carries custom claims
    // set by /api/staff/login (see lib/staffAuth.js ensureStaffAuthUser):
    //   { role: 'kitchen' | 'waiter', rid: <restaurantId>, staffId, kind: 'staff' }
    // We verify rid matches the path restaurantId so a staff of restaurant A
    // can never touch restaurant B's data.
    function isStaff(restaurantId) {
      return isAuth() &&
        request.auth.token.kind == 'staff' &&
        request.auth.token.rid == restaurantId;
    }

    // Phase 4 hardening (F17, 17 May 2026): live-checked staff.
    // pages/api/staff/update.js calls adminAuth.revokeRefreshTokens
    // + updateUser({disabled:true}) when an admin toggles a staff
    // member's isActive to false, but the staff's CURRENT id token
    // remains valid until its 1-hour TTL expires — during that
    // window they can still hit Firestore. This helper adds an
    // exact-doc Firestore read to the rule eval so a write from a
    // disabled staff is refused immediately (the read is cached
    // per-evaluation by Firestore, so a single rule eval that
    // calls isActiveStaff() twice only pays for it once).
    //
    // Used ONLY on update/delete/write rules. Reads still go through
    // plain isStaff() — a disabled staff briefly seeing stale data
    // on their dashboard is acceptable; them WRITING into the
    // restaurant's orders/tableBills/etc. after being disabled is not.
    function isActiveStaff(restaurantId) {
      return isStaff(restaurantId) &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)/staff/$(request.auth.token.staffId)).data.isActive == true;
    }

    // ── Restaurants ──────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // Public: read any restaurant (for subdomain routing + real-time status detection)
      allow read: if true;
      // Restaurant admin: read their own restaurant doc
      allow read: if isRestaurantAdmin(restaurantId);
      // Restaurant admin: update their own settings & metadata.
      //
      // Phase 3 hardening (H1, 16 May 2026): switched from BLOCKLIST to
      // ALLOWLIST. The old blocklist only blocked 5 fields (isActive,
      // plan, paymentStatus, maxItems, maxStorageMB), letting admin
      // self-modify dangerous fields like:
      //   - trialEndsAt (extend their own trial)
      //   - subdomain (steal another restaurant's subdomain)
      //   - gatewayActive / autoConfirmActive (flip on payment flows
      //     without configuring real credentials)
      //   - welcomeEmailSentAt (manipulate audit timestamps)
      //   - ownerUid (transfer their account to someone else's UID)
      // The allowlist below is the COMPLETE set of fields the admin
      // legitimately edits via the admin UI. Every entry was verified
      // by grepping every updateRestaurant() call site in the codebase
      // (pages/admin/settings.js, items.js, notifications.js,
      // admin/index.js, qrcode.js). Petpooja sync + payment config
      // writes happen via the Admin SDK in API routes (bypass these
      // rules) so they're unaffected.
      //
      // Adding a new admin-editable field? Add it to this list AND
      // make sure the corresponding admin UI exists. Forgetting the
      // list will surface as "permission denied" in the toast.
      allow update: if isRestaurantAdmin(restaurantId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          // Core info (admin/settings.js)
          'name', 'address', 'phone', 'city', 'cuisine',
          // Tax + billing (admin/settings.js)
          'gstPercent', 'serviceChargePercent', 'gstNumber', 'hsnCode', 'fssaiNo',
          // Payment + branding (admin/settings.js)
          'upiId', 'billFooter', 'notificationsEmail',
          // Menu organisation (admin/items.js)
          'categoryOrder', 'categoryImages',
          // Operational toggles (admin/notifications.js)
          'waiterCallsEnabled',
          // Onboarding (admin/index.js)
          'onboardingComplete',
          // Counter incremented by lib/db.js submitRequestAndPublish()
          // when a new menu item is created. NOT a security risk:
          // restaurant admins set their own item count organically by
          // adding items, and the maxItems plan cap is enforced
          // separately by the UI + server. (Added 18 May 2026 after
          // Prabu reported the "Permission denied — check Firestore
          // rules" toast on every item add — item was created but the
          // counter bump landed on a closed-door rule.)
          'itemsUsed',
          // Future / defensive fields admin code references
          'tableCount', 'logoUrl', 'isAcceptingOrders',
          // Audit stamp from lib/db.js withActor() — rides on every write
          'lastModifiedBy', 'lastModifiedAt'
        ]);
      // Phase 3 hardening (H4 + W1, 16 May 2026): client-side create
      // is now BANNED. The previous `allow create: if isAuth();` let
      // any signed-in user write a restaurant doc with arbitrary
      // values for plan / maxItems / paymentStatus / trialEndsAt /
      // ownerUid — they could mint a free Pro plan with inflated
      // limits, mark themselves paid, or claim another user's UID.
      // All signups now go through /api/restaurant/create which
      // validates inputs server-side and forces the trial defaults.
      // Superadmin creation (allow read, write below) is untouched —
      // /superadmin/restaurants still creates via saDb client SDK
      // since the superadmin token bypasses this rule.
      //
      // No explicit `allow create` here = default deny. The endpoint
      // uses Admin SDK which bypasses rules entirely.
      // Super admin: full access (covers create/update/delete via `write`)
      allow read, write: if isSuperAdmin();

      // ── Menu Items ────────────────────────────────────────────
      match /menuItems/{itemId} {
        // Public: read active items (customer menu page)
        allow read: if true;
        // Restaurant admin: full read + write their own items
        // (covers sold-out toggle, drag reorder, edits)
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
        // Public: allow incrementing views, arViews, and ratings (no auth needed).
        // Hardened: counters monotonically increase; per-write deltas are
        // bounded so a tampered client can't write ratingSum=999999 in one
        // request. ratingAvg is bounded to [0, 5]. Schema is locked.
        allow update: if !isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['views', 'arViews', 'ratingSum', 'ratingCount', 'ratingAvg']) &&
          request.resource.data.get('views', 0) >= resource.data.get('views', 0) &&
          request.resource.data.get('views', 0) <= resource.data.get('views', 0) + 1 &&
          request.resource.data.get('arViews', 0) >= resource.data.get('arViews', 0) &&
          request.resource.data.get('arViews', 0) <= resource.data.get('arViews', 0) + 1 &&
          request.resource.data.get('ratingCount', 0) >= resource.data.get('ratingCount', 0) &&
          request.resource.data.get('ratingCount', 0) <= resource.data.get('ratingCount', 0) + 1 &&
          request.resource.data.get('ratingSum', 0) >= resource.data.get('ratingSum', 0) &&
          request.resource.data.get('ratingSum', 0) <= resource.data.get('ratingSum', 0) + 5 &&
          request.resource.data.get('ratingAvg', 0) >= 0 &&
          request.resource.data.get('ratingAvg', 0) <= 5;
      }

      // ── Analytics ─────────────────────────────────────────────
      // Visit + item-view tracking from the (unauthenticated) customer
      // menu page. No auth required, but tightly schema-locked so a
      // malicious client can't spam arbitrary doc ids or fields, and
      // counters can never decrease (increment-only).
      match /analytics/{docId} {
        allow read: if true;
        // Doc id must match the YYYY-MM-DD format used by todayKey() in
        // lib/db.js. Only the known analytics fields may be present.
        allow create: if docId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
          request.resource.data.keys().hasOnly([
            'date', 'totalVisits', 'uniqueVisitors', 'repeatVisitors',
            'sessions', 'hourlyVisits', 'itemViews', 'arViews'
          ]);
        allow update: if docId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'date', 'totalVisits', 'uniqueVisitors', 'repeatVisitors',
            'sessions', 'hourlyVisits', 'itemViews', 'arViews'
          ]) &&
          request.resource.data.get('totalVisits', 0) >= resource.data.get('totalVisits', 0) &&
          request.resource.data.get('uniqueVisitors', 0) >= resource.data.get('uniqueVisitors', 0) &&
          request.resource.data.get('repeatVisitors', 0) >= resource.data.get('repeatVisitors', 0) &&
          request.resource.data.get('itemViews', 0) >= resource.data.get('itemViews', 0) &&
          request.resource.data.get('arViews', 0) >= resource.data.get('arViews', 0);
        // Restaurant admin: full access (legitimate manual edits, debugging)
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── Waiter Calls ──────────────────────────────────────────
      match /waiterCalls/{callId} {
        // Public: customers can create waiter call (from menu page).
        // Phase 4 hardening (F6, 17 May 2026): schema-locked. Pre-
        // hardening, `allow create: if true` accepted ANY shape with
        // ANY field sizes — a spammer could insert 1 MB strings into
        // arbitrary fields, pollute analytics, or inject script tags
        // that ride into the admin waiterCalls UI. The allow-list
        // below mirrors lib/db.js createWaiterCall + the customer
        // page call site at pages/restaurant/[subdomain]/index.js.
        // status MUST be 'pending' (admin/staff transition it from
        // there via the update rule above).
        allow create: if request.resource.data.keys().hasOnly([
                        'reason', 'tableNumber', 'restaurantName',
                        'status', 'createdAt',
                      ]) &&
                      request.resource.data.reason is string &&
                      request.resource.data.reason.size() > 0 &&
                      request.resource.data.reason.size() < 80 &&
                      request.resource.data.tableNumber is string &&
                      request.resource.data.tableNumber.size() < 32 &&
                      request.resource.data.restaurantName is string &&
                      request.resource.data.restaurantName.size() < 120 &&
                      request.resource.data.status == 'pending';
        // Restaurant admin: read + update (mark resolved)
        allow read, update, delete: if isRestaurantAdmin(restaurantId);
        // Staff (kitchen or waiter): read for dashboards (cheap),
        // update/delete via isActiveStaff so a just-disabled staff
        // can't resolve calls until their token expires (F17).
        allow read:                  if isStaff(restaurantId);
        allow update, delete:        if isActiveStaff(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── Feedback ──────────────────────────────────────────────
      // Phase 4 hardening (F6, 17 May 2026): same schema-lock
      // rationale as waiterCalls above. Customer write site is
      // pages/restaurant/[subdomain]/index.js submitFeedback() —
      // every field in that call appears in the allow-list below.
      // isRead is forced to false on create so admins can rely on
      // it as a server-truth "new feedback" flag; they flip it true
      // via the update rule when they read it.
      match /feedback/{feedbackId} {
        allow create: if request.resource.data.keys().hasOnly([
                        'rating', 'comment', 'orderItems',
                        'tableNumber', 'orderId', 'orderTotal',
                        'isRead', 'createdAt',
                      ]) &&
                      request.resource.data.rating is int &&
                      request.resource.data.rating >= 1 &&
                      request.resource.data.rating <= 5 &&
                      request.resource.data.comment is string &&
                      request.resource.data.comment.size() <= 500 &&
                      request.resource.data.orderItems is list &&
                      request.resource.data.orderItems.size() <= 50 &&
                      request.resource.data.orderTotal is number &&
                      request.resource.data.orderTotal >= 0 &&
                      request.resource.data.isRead == false;
        allow read, update, delete: if isRestaurantAdmin(restaurantId);
        allow read, write: if isSuperAdmin();
      }

      // ── Orders ────────────────────────────────────────────────
      // SECURITY (Phase 2 hardening — 16 May 2026):
      //
      //   C1 — Public paymentStatus updates are now restricted to a
      //        specific transition. Customers can only set
      //        paymentStatus = 'online_requested' (and only from
      //        'unpaid' / 'pending'). Previously the rule blocked
      //        which fields could change but NOT what values were
      //        written, so anyone with an orderId could mark any
      //        order paid_online without paying.
      //
      //   C3 — Public order creation now validates the shape +
      //        forces safe initial state. Previously `allow create:
      //        if true` accepted any shape, including
      //        paymentStatus: 'paid_online' from creation — letting
      //        an attacker plant fake-paid orders that staff would
      //        fulfill thinking they were real.
      //
      //   C2 — Bulk-read vulnerability (anyone could
      //        `getDocs(collection(...))` to dump all orders + PII
      //        for any restaurant) FIXED in Phase 2.5 (16 May 2026):
      //        - `allow get` (single-doc) still public so customers
      //          can read their own order by ID for the confirmation
      //          screen + per-doc listeners on the bill view.
      //        - `allow list` restricted to authenticated admin /
      //          staff / superadmin. The customer bill listener no
      //          longer needs `list` — it reads `tableBills.orderIds`
      //          and sets up per-doc onSnapshot listeners for each.
      //          Same real-time UX, no bulk-dump exposure.

      match /orders/{orderId} {
        // ── CREATE (C3 hardening) ────────────────────────────────
        // Public customers can create orders, but the payload must:
        //   - include the core required fields (items, total, restaurantName)
        //   - start in a safe initial state (paymentStatus must be 'unpaid';
        //     status must be 'pending' or 'awaiting_payment')
        //   - have a sane total (number, positive, capped to prevent
        //     overflow / Firestore-doc-size attacks)
        //   - have items array within reasonable bounds (1-100 items)
        // Fields beyond the required ones are permitted (customer page
        // adds optional metadata like couponCode, customerPhone, etc.)
        // — we don't lock the full schema because that makes the rule
        // brittle to harmless additions.
        // 18 May 2026: relaxed `total > 0` to `total >= 0` after Prabu
        // reported intermittent "Order failed: permission-denied" on
        // takeaway. A 100% coupon or full-discount order would land
        // with grandTotal=0 (legit case) but the strict > 0 rejected
        // them. The negative-total guard remains (a malicious client
        // sending -5000 to "refund" themselves still fails). The
        // upper cap stays at 1,000,000 INR.
        allow create: if
          request.resource.data.keys().hasAll(['items', 'total', 'paymentStatus', 'status']) &&
          request.resource.data.paymentStatus == 'unpaid' &&
          request.resource.data.status in ['pending', 'awaiting_payment'] &&
          request.resource.data.total is number &&
          request.resource.data.total >= 0 &&
          request.resource.data.total < 1000000 &&
          request.resource.data.items is list &&
          request.resource.data.items.size() > 0 &&
          request.resource.data.items.size() <= 100;

        // ── READ ─────────────────────────────────────────────────
        // Single-doc reads (`get`) are public — customer needs to read
        // their own order by ID for the confirmation screen + per-doc
        // listeners on the bill view. Reading a single doc requires
        // knowing its 20-char unguessable Firestore-generated ID.
        allow get: if true;

        // List queries are admin/staff only (Phase 2.5 — C2 fix). The
        // customer bill listener no longer needs `list` because the
        // tableBills doc tracks orderIds (see tableBills rule above)
        // and the listener iterates them via per-doc reads instead of
        // a `where('billId', '==', X)` query.
        allow list: if isRestaurantAdmin(restaurantId)
                    || isStaff(restaurantId)
                    || isSuperAdmin();

        // ── UPDATE: public payment selection (C1 hardening) ──────
        // Customers can:
        //   1. Pick a payment method → set paymentStatus to one of
        //      cash_requested / card_requested / online_requested
        //      (the "_requested" signal tells admin "customer is paying").
        //   2. Switch methods → reset paymentStatus back to 'unpaid'
        //      first, then pick a new one.
        // Customers CANNOT directly set paid_cash / paid_card /
        // paid_online / paid / refunded — those are the actual money-
        // received states, reached only via the gateway webhook
        // (Admin SDK bypasses rules) or admin/staff confirming the
        // payment manually (authenticated paths).
        //
        // Belt-and-braces: also block transitions FROM a paid state,
        // so an attacker can't "un-pay" their own order even by
        // setting paymentStatus back to unpaid.
        //
        // 18 May 2026: also block writes when the order has been
        // cancelled — pre-fix, a cancelled order could still receive
        // cash_requested / online_requested signals from the
        // customer page (cancellation only clears the displayed bill
        // but didn't gate the rule), letting a customer accidentally
        // pay for an order the admin had already voided. The H5
        // server-side check on /api/payment/intent catches the
        // gateway path, but cash/card are direct Firestore writes
        // that bypass it — only the rule can block here.
        //
        // lastModifiedBy + lastModifiedAt are audit fields stamped
        // by lib/db.js.withActor() on every mutation — they ride
        // along in affectedKeys() so the rule passes.
        // Belt-and-braces: triple check that prevents the public
        // paymentStatus update from landing on a cancelled order.
        // resource.data.status — Firestore returns undefined when the
        // field is missing, which compares not-equal to 'cancelled'
        // by default. We use .get('status','') to make the absent
        // case explicit ('' != 'cancelled' → pass), AND we add a
        // second guard `resource.data.keys().hasAny(['status'])` so
        // legacy docs without a status field aren't accidentally
        // blocked.
        allow update: if
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['paymentStatus', 'paymentUpdatedAt', 'lastModifiedBy', 'lastModifiedAt']) &&
          resource.data.get('status', 'pending') != 'cancelled' &&
          !(resource.data.paymentStatus in ['paid_cash', 'paid_card', 'paid_online', 'paid', 'refunded']) &&
          request.resource.data.paymentStatus in ['unpaid', 'cash_requested', 'card_requested', 'online_requested'];

        // ── UPDATE: public takeaway cancel ────────────────────────
        // Customers can cancel their OWN takeaway order while it's
        // still parked in awaiting_payment. The kitchen hasn't
        // started any work yet so a clean cancellation is safe.
        // Restrictions:
        //   - current status MUST be 'awaiting_payment'
        //   - new status MUST be 'cancelled'
        //   - only the cancel-related fields can change
        //   - if paymentStatus is updated in this write, it MUST go
        //     to 'unpaid' (releases any stale *_requested signal that
        //     was set when the customer picked a method earlier —
        //     prevents the admin payments page from showing a
        //     cancelled order as "still waiting for payment").
        allow update: if
          resource.data.status == 'awaiting_payment' &&
          request.resource.data.status == 'cancelled' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'cancelledAt', 'cancelledBy', 'paymentStatus', 'paymentUpdatedAt', 'lastModifiedBy', 'lastModifiedAt']) &&
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus']) ||
            request.resource.data.paymentStatus == 'unpaid'
          );

        // ── Restaurant admin + staff + super admin full access ───
        allow read, update, delete: if isRestaurantAdmin(restaurantId);
        // F17: split staff into read (cheap, plain isStaff) +
        // update/delete (isActiveStaff so a just-disabled staff
        // can't mutate orders during their token's grace period).
        allow read:                 if isStaff(restaurantId);
        allow update, delete:       if isActiveStaff(restaurantId);
        allow read, write: if isSuperAdmin();
      }

      // ── Order Counters ────────────────────────────────────────
      // Per-day counter for sequential order numbering. Path: orderCounters/{YYYY-MM-DD}
      // Schema: { nextOrder: <positive int>, updatedAt: <timestamp> }
      //
      // Reads + writes happen during the createOrder transaction, which runs as the
      // unauthenticated customer session. We must allow public access, but tightly:
      //   - The doc id must look like a YYYY-MM-DD date (prevents arbitrary doc creation)
      //   - On write, only nextOrder + updatedAt may be present
      //   - nextOrder must be a positive integer
      //   - nextOrder may only increase (no resetting to 0 or going backwards by malicious clients)
      match /orderCounters/{dayKey} {
        // Public: read the current counter value (the transaction needs to read before incrementing)
        allow read: if true;

        // Public: create a new day's counter doc (first order of the day).
        // Only allow if the doc id matches YYYY-MM-DD format and the body is well-formed.
        allow create: if dayKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
          request.resource.data.keys().hasOnly(['nextOrder', 'updatedAt']) &&
          request.resource.data.nextOrder is int &&
          request.resource.data.nextOrder > 0;

        // Public: update the counter, but only by increasing nextOrder.
        // This prevents a malicious client from resetting the counter to 0 to cause collisions.
        allow update: if dayKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nextOrder', 'updatedAt']) &&
          request.resource.data.nextOrder is int &&
          request.resource.data.nextOrder > resource.data.nextOrder;

        // Restaurant admin: full access (for migration / debugging)
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── Offers ────────────────────────────────────────────────
      match /offers/{offerId} {
        // Public: read all offers (customer menu page)
        allow read: if true;
        // Restaurant admin: manage their offers (create, update, delete)
        allow write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow write: if isSuperAdmin();
      }

      // ── Combos ────────────────────────────────────────────────
      match /combos/{comboId} {
        // Public: read all combos (customer menu page)
        allow read: if true;
        // Restaurant admin: manage their combos
        allow write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow write: if isSuperAdmin();
      }

      // ── Table Sessions ────────────────────────────────────────
      match /tableSessions/{tableNumber} {
        // Public: read session to validate QR sid (customer menu page)
        allow read: if true;
        // Restaurant admin: activate, clear, manage sessions
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
        // Phase C — Staff (kitchen/waiter): can update ONLY currentBillId
        // so the bill auto-close hook (markOrderPaidAs) can clear the
        // pointer when all orders in a bill are paid. sid + isActive +
        // expiresAt remain admin-only — staff cannot deactivate tables
        // or rotate the security token.
        // F17 (17 May 2026): isActiveStaff so a disabled staff can't
        // re-point the bill within the 1h token grace window.
        allow update: if isActiveStaff(restaurantId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBillId']);
      }

      // ── Table Bills (running tabs for dine-in) ────────────────
      // One bill per table session — multiple orders at the same table
      // attach to the same bill via order.billId. Bill creation runs
      // server-side via /api/tableBill/get-or-create (Admin SDK, bypasses
      // these rules) so we don't allow public CREATE here. Customers and
      // staff just need to READ the bill to see their running total.
      //
      // Phase 2.5 (16 May 2026): Customer also needs to UPDATE the bill's
      // orderIds array — appending each new orderId via arrayUnion — so
      // the bill listener can discover orders via the bill doc instead of
      // a public-list query on orders (CRITICAL audit C2). We restrict
      // this write tightly:
      //   1. Only the orderIds field may change (no touching status,
      //      tableNumber, etc.)
      //   2. The new array must be a SUPERSET of the old (arrayUnion
      //      semantics — customer can append but not delete).
      //   3. Size cap: 200 orderIds — prevents a bot from pumping
      //      thousands of fake ids into a bill (cost attack on listener
      //      fan-out). Real tables would never accumulate this many.
      match /tableBills/{billId} {
        // Public: read so the customer can see their running bill
        allow read: if true;

        // Public: arrayUnion of orderIds only (Phase 2.5 — see comment above).
        // Uses .get('orderIds', []) to handle pre-Phase-2.5 bills that
        // don't have the field at all — first arrayUnion call lands and
        // the field is created on write. New array must be a superset
        // of the old (arrayUnion semantics — customer can append but
        // never delete). Capped at 200 entries to prevent a malicious
        // client from inflating one bill into a million-orderId monster
        // (cost attack on listener fan-out).
        allow update: if
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['orderIds']) &&
          request.resource.data.orderIds is list &&
          request.resource.data.orderIds.size() <= 200 &&
          request.resource.data.orderIds.size() >= resource.data.get('orderIds', []).size() &&
          resource.data.get('orderIds', []).toSet().difference(request.resource.data.orderIds.toSet()).size() == 0;

        // Restaurant admin: full access (close, manage, audit)
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Staff (kitchen/waiter): read for the bill UI, write only
        // when their account is currently active (F17, 17 May 2026).
        allow read: if isStaff(restaurantId);
        allow write: if isActiveStaff(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── Areas (floor-plan sections — Phase 0, 20 May 2026) ────
      // A/C, Non-A/C, Rooftop, Bar, etc. Pure config that groups
      // tables on the Table View dashboard. NOT public — the
      // anonymous customer page never needs the floor plan (it scans
      // a single table's QR). Admin manages; staff read (their
      // captain view needs the area grouping).
      match /areas/{areaId} {
        allow read:  if isRestaurantAdmin(restaurantId) || isStaff(restaurantId) || isSuperAdmin();
        allow write: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── Day Closes (Z-report snapshots — Phase 1b, 20 May 2026) ──
      // Frozen end-of-day reconciliation records (cash float, sales by
      // mode, tax, variance). Financial data — admin + superadmin only,
      // never staff, never public.
      match /dayCloses/{dateKey} {
        allow read, write: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── Tables (floor-plan registry — Phase 0, 20 May 2026) ──
      // Physical tables: { label, code, areaId, capacity, sortOrder }.
      // `code` is the QR identity → maps to tableSessions/{code} and
      // the /r/{subdomain}/{code} QR URL, so the legacy numeric QR
      // flow keeps working. Status (blank/running/printed/paid) is
      // NOT stored here — it's derived live from tableBills + orders.
      // Admin manages the registry; staff read it for the Table View.
      match /tables/{tableId} {
        allow read:  if isRestaurantAdmin(restaurantId) || isStaff(restaurantId) || isSuperAdmin();
        allow write: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── AR Model Requests ─────────────────────────────────────
      match /requests/{requestId} {
        // Restaurant admin: read + create their own requests
        allow read, create: if isRestaurantAdmin(restaurantId);
        // Super admin: read + write all (approve/reject)
        allow read, write: if isSuperAdmin();
      }

      // ── Coupons ───────────────────────────────────────────────
      // Coupons are NOT publicly readable — customers validate through the
      // server-side /api/coupons/validate endpoint (which uses the Admin SDK
      // and bypasses these rules). This prevents coupon-scraping bots that
      // abuse the whole coupon list.
      match /coupons/{couponId} {
        allow read: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
        allow create, update, delete: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── Staff Logins ──────────────────────────────────────────
      // Staff accounts are managed by the restaurant owner. PIN verification
      // happens server-side via /api/staff/login (bcrypt + rate limit), so
      // the staff collection is NEVER publicly readable — only the admin
      // and super-admin can read/write.
      //
      // May 8: a logged-in staff member ALSO needs to read their OWN
      // staff doc so kitchen.js / waiter.js can run a Firestore
      // listener on it — that's how we detect a manager-triggered
      // disable / delete in real time. Without this allowance the
      // listener fires permission-denied immediately after sign-in
      // and the staff gets bounced back to /staff/login. We scope it
      // tightly: staff role + matching restaurantId + matching
      // staffId on the path. PIN-hash exposure is not a concern
      // because the staff already authenticated with the PIN.
      match /staff/{staffId} {
        allow read: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
        allow read: if isStaff(restaurantId) &&
          request.auth.token.staffId == staffId;
        allow write: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── Private (gateway credentials, future secrets) ─────────
      // Phase H — restaurants/{rid}/private/{docId}
      // Holds the Paytm Business merchantId + merchantKey that the
      // restaurant admin pasted into /admin/gateway. Server-side reads
      // happen via the Admin SDK (which bypasses these rules), so
      // /api/payment/intent + /api/payment/webhook can still reach
      // the doc. Customer client SDK + restaurant admin client SDK
      // are both blocked — they only see the public stub fields
      // (gatewayActive + gatewayProvider) on the parent restaurant
      // doc, NEVER the merchantKey.
      match /private/{docId} {
        allow read, write: if false;
      }
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{userId} {
      // User reads their own doc (for role check after login)
      allow read: if isAuth() && request.auth.uid == userId;
      // Super admin: read all user docs
      allow read: if isSuperAdmin();
      // Allow user creation during restaurant onboarding
      allow create: if isAuth();
      // Only super admin can update roles / arbitrary fields
      allow update: if isSuperAdmin();
      // Phase 3 hardening (W2, 16 May 2026): allow a signed-in user to
      // sync their own users/{uid}.email field to match Firebase Auth.
      // Background: admins change their email via
      // pages/admin/settings/security.js using verifyBeforeUpdateEmail
      // — Firebase swaps the auth email only after the verification
      // link is clicked. Before W2, nothing wrote the new email back to
      // users/{uid}.email, so lib/dailySummary.js (which uses that
      // field as the fallback summary recipient when notificationsEmail
      // is empty) kept delivering to the OLD inbox indefinitely.
      // hooks/useAuth.js now writes here on every onAuthStateChanged
      // when firebaseUser.email differs from userData.email.
      // Allowlist is strict: only `email` (the synced value) and an
      // audit stamp `emailSyncedAt`. Role / restaurantId / anything
      // else still requires superadmin.
      allow update: if isAuth() && request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['email', 'emailSyncedAt']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 0 &&
        request.resource.data.email.size() < 200;
    }

    // ── Plans ─────────────────────────────────────────────────────
    match /plans/{planId} {
      // Public: anyone can read plans (landing page + subscription page).
      // F18 (17 May 2026): intentional. Plan pricing + limits are
      // public marketing data (rendered on /pricing and /subscription
      // unauthenticated). lib/plans.js is the source-of-truth for
      // code paths; this Firestore mirror only exists so the
      // superadmin can adjust pricing without a redeploy. No PII
      // or business secrets here.
      allow read: if true;
      // Only super admin can manage plans
      allow write: if isSuperAdmin();
    }

    // ── Top-level AR Model Requests ───────────────────────────────
    match /requests/{reqId} {
      // Restaurant admin: read + create
      allow read, create: if isAuth();
      // Super admin: full access
      allow read, write: if isSuperAdmin();
    }

    // ── System Config (super-admin only) ──────────────────────────
    // Holds platform-wide settings the super admin needs to rotate without
    // a redeploy. Currently just `email` (sender Gmail credentials for the
    // daily summary cron). Restaurant admins MUST NOT see these — the
    // appPassword is a secret. Server-side reads happen via the Admin SDK
    // (which bypasses these rules), so the cron + /api/email/send-test
    // can still reach the doc.
    match /systemConfig/{configId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Rate Limit Counters ──────────────────────────────────────
    // Phase 4 hardening (F2, 17 May 2026): explicit deny so the
    // intent is documented in-code (was previously implicit via
    // default-deny). Written exclusively by lib/staffAuth.js +
    // lib/rateLimit.js via the Admin SDK (bypasses these rules);
    // no client ever has a reason to read or write here.
    match /rateLimit/{docId} {
      allow read, write: if false;
    }

  }
}
