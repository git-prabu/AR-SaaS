rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuth() && getUserData().role == 'superadmin';
    }

    function isRestaurantAdmin(restaurantId) {
      return isAuth() &&
        getUserData().role == 'restaurant' &&
        getUserData().restaurantId == restaurantId;
    }

    // ── Restaurants ──────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // Public: read any restaurant (for subdomain routing + real-time status detection)
      allow read: if true;
      // Restaurant admin: read their own restaurant doc
      allow read: if isRestaurantAdmin(restaurantId);
      // Restaurant admin: update their own settings & metadata
      // Blocked fields: isActive, plan, paymentStatus, maxItems, maxStorageMB
      // (those are controlled by super admin only)
      allow update: if isRestaurantAdmin(restaurantId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['isActive', 'plan', 'paymentStatus', 'maxItems', 'maxStorageMB']);
      // Authenticated users: create restaurant (signup/onboarding)
      allow create: if isAuth();
      // Super admin: full access
      allow read, write: if isSuperAdmin();

      // ── Menu Items ────────────────────────────────────────────
      match /menuItems/{itemId} {
        // Public: read active items (customer menu page)
        allow read: if true;
        // Restaurant admin: full read + write their own items
        // (covers sold-out toggle, drag reorder, edits)
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
        // Public: allow incrementing views, arViews, and ratings (no auth needed)
        allow update: if !isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['views', 'arViews', 'ratingSum', 'ratingCount', 'ratingAvg']);
      }

      // ── Analytics ─────────────────────────────────────────────
      match /analytics/{docId} {
        // Public read + create/update for visit tracking
        allow read: if true;
        allow create, update: if true;
        // Only admins can delete analytics data
        allow delete: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── Waiter Calls ──────────────────────────────────────────
      match /waiterCalls/{callId} {
        // Public: customers can create waiter call (from menu page)
        allow create: if true;
        // Restaurant admin: read + update (mark resolved)
        allow read, update, delete: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── Feedback ──
      match /feedback/{feedbackId} {
        allow create: if true;
        allow read, update, delete: if isRestaurantAdmin(restaurantId);
        allow read, write: if isSuperAdmin();
      }

      // ── Orders ────────────────────────────────────────────────
      match /orders/{orderId} {
        // Public: customers can create orders (from menu cart)
        allow create: if true;
        // Public: customers can read their own order by orderId
        // (for order confirmation screen — no auth required)
        allow read: if true;
        // Public: customers can update payment status only (Confirm Payment button)
        allow update: if request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['paymentStatus', 'paymentUpdatedAt']);
        // Restaurant admin: read + update status (pending→preparing→ready→served)
        allow read, update, delete: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── Offers ────────────────────────────────────────────────
      match /offers/{offerId} {
        // Public: read all offers (customer menu page)
        allow read: if true;
        // Restaurant admin: manage their offers (create, update, delete)
        allow write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow write: if isSuperAdmin();
      }

      // ── Combos ────────────────────────────────────────────────
      match /combos/{comboId} {
        // Public: read all combos (customer menu page)
        allow read: if true;
        // Restaurant admin: manage their combos
        allow write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow write: if isSuperAdmin();
      }

      // ── Table Sessions ────────────────────────────────────────
      match /tableSessions/{tableNumber} {
        // Public: read session to validate QR sid (customer menu page)
        allow read: if true;
        // Restaurant admin: activate, clear, manage sessions
        allow read, write: if isRestaurantAdmin(restaurantId);
        // Super admin: full access
        allow read, write: if isSuperAdmin();
      }

      // ── AR Model Requests ─────────────────────────────────────
      match /requests/{requestId} {
        // Restaurant admin: read + create their own requests
        allow read, create: if isRestaurantAdmin(restaurantId);
        // Super admin: read + write all (approve/reject)
        allow read, write: if isSuperAdmin();
      }

      // ── Coupons ───────────────────────────────────────────────
      match /coupons/{couponId} {
        // Public read: customers validate coupon codes client-side
        // TODO: migrate coupon validation to server-side API to avoid exposing all coupon data
        allow read: if true;
        // Only admins can create, update, or delete coupons
        allow create, update, delete: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }

      // ── Staff Logins ──────────────────────────────────────────
      // Staff login now uses server-side API (/api/staff/verify)
      // so PINs no longer need to be publicly readable
      match /staff/{staffId} {
        allow read: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
        allow write: if isRestaurantAdmin(restaurantId) || isSuperAdmin();
      }
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{userId} {
      // User reads their own doc (for role check after login)
      allow read: if isAuth() && request.auth.uid == userId;
      // Super admin: read all user docs
      allow read: if isSuperAdmin();
      // Allow user creation during restaurant onboarding
      allow create: if isAuth();
      // Only super admin can update roles
      allow update: if isSuperAdmin();
    }

    // ── Plans ─────────────────────────────────────────────────────
    match /plans/{planId} {
      // Public: anyone can read plans (landing page + subscription page)
      allow read: if true;
      // Only super admin can manage plans
      allow write: if isSuperAdmin();
    }

    // ── Top-level AR Model Requests ───────────────────────────────
    match /requests/{reqId} {
      // Restaurant admin: read + create
      allow read, create: if isAuth();
      // Super admin: full access
      allow read, write: if isSuperAdmin();
    }

  }
}
