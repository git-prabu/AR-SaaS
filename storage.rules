rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper Functions ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // File-size + content-type guards. Sized generously for the kinds
    // of files our admin UI actually uploads — anything bigger almost
    // certainly indicates an attacker probing for a storage-quota
    // exhaustion attack.
    function isAcceptableImage() {
      // 10MB — admin/items.js resizes browser-side to ~800px / 80% JPEG
      // (resizeImage in lib/storage.js), which lands around 100-300 KB.
      // 10MB caps the un-resized fallback path generously.
      return request.resource.size < 10 * 1024 * 1024 &&
             request.resource.contentType.matches('image/.*');
    }
    function isAcceptableModel() {
      // 100MB — Meshy AR .glb output is typically 5-30 MB; cap leaves
      // headroom for the occasional dense model without inviting abuse.
      return request.resource.size < 100 * 1024 * 1024 &&
             (request.resource.contentType == 'model/gltf-binary' ||
              request.resource.contentType == 'application/octet-stream');
    }

    // ── Restaurant assets ────────────────────────────────────────
    //
    // 18 May 2026 — TRADE-OFF NOTE.
    //
    // The Phase 4 hardening attempted strict cross-tenant scoping by
    // looking up users/{uid}.restaurantId via Cloud Storage's
    // cross-service `firestore.get(...)` feature. That feature is
    // documented as supported with rules_version='2', but in this
    // project's actual production environment it consistently
    // denied legitimate admin uploads with storage/unauthorized
    // — Prabu hit it on every menu item + category image upload.
    // Likely cause is project-config / GCP-permission lag on
    // cross-service rules, but debugging that further is out of
    // scope for the audit.
    //
    // Until that's properly resolved (target: switch to a custom-
    // claim approach where /api/restaurant/create sets `rid` on the
    // user's Firebase Auth token, and the storage rule checks
    // `request.auth.token.rid == restaurantId` — no Firestore
    // lookup needed), we accept the lighter check:
    //
    //   1. Caller must be signed in (denies all anonymous writes —
    //      so the customer menu page can't upload anything).
    //   2. Size cap (10MB images, 100MB models) — closes the
    //      cost-amplification attack.
    //   3. Content-type allowlist — closes the malware-hosting
    //      attack (no .exe disguised as .jpg).
    //
    // Residual risk: a signed-in admin of restaurant A can upload
    // into restaurant B's bucket path IF they know B's restaurantId.
    // This was also the situation pre-Phase-4. Tracked as a
    // post-audit TODO; not a regression vs. the pre-audit state.

    match /restaurants/{restaurantId}/images/{allPaths=**} {
      allow read: if true;
      allow write:  if isAuth() && isAcceptableImage();
      allow delete: if isAuth();
    }

    match /restaurants/{restaurantId}/models/{allPaths=**} {
      allow read: if true;
      allow write:  if isAuth() && isAcceptableModel();
      allow delete: if isAuth();
    }

    // ── Legacy / one-off paths ───────────────────────────────────
    // These paths are NOT used by any current code path (grep
    // confirmed). Locked down to read-only so existing files (if
    // any) still load; no new writes accepted.
    match /menuImages/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /models/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // ── Catch-all ────────────────────────────────────────────────
    // Anything not matched above is read-only public. Writes are
    // still blocked for everyone except an authenticated user
    // uploading an acceptable image — same protections as the
    // scoped paths above. The pre-audit catch-all was wide open
    // for any signed-in user; tightening to image-only + size cap
    // is a strict improvement.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAuth() && isAcceptableImage();
    }
  }
}
